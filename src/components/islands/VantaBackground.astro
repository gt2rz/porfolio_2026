---
// Vanta.js NET effect — client:load island
// Renders an interactive network of nodes that react to mouse
---

<div id="vanta-bg" aria-hidden="true"></div>

<script>
  import * as THREE from 'three';

  let vantaEffect: ReturnType<typeof import('vanta/dist/vanta.net.min').default> | null = null;

  async function initVanta() {
    // Destroy previous instance on View Transition
    if (vantaEffect) {
      vantaEffect.destroy();
      vantaEffect = null;
    }

    const el = document.getElementById('vanta-bg');
    if (!el) return;

    const VANTA = await import('vanta/dist/vanta.net.min');

    vantaEffect = VANTA.default({
      el,
      THREE,
      mouseControls: true,
      touchControls: true,
      gyroControls: true,
      // Cyber green palette
      color: 0x00e639,    // líneas — Cyber Green
      color2: 0x00ff66,   // nodos — verde más brillante
      backgroundColor: 0x050505,
      points: 6,
      maxDistance: 30,
      spacing: 18,
      // Performance
      scale: 1.0,
      scaleMobile: 1.0,
    });
  }

  // Cleanup on View Transition out
  document.addEventListener('astro:before-swap', () => {
    if (vantaEffect) {
      vantaEffect.destroy();
      vantaEffect = null;
    }
  });

  document.addEventListener('astro:page-load', initVanta);
</script>

<style>
  #vanta-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    opacity: 0.2;  /* controla transparencia global de líneas y nodos */
  }

  #vanta-bg canvas {
    opacity: 1;
  }
</style>
