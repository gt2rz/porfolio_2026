---
import { getSystemTime } from '../../lib/utils';
const systemTime = getSystemTime();
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <div class="footer__left">
      <span class="footer__brand">TERMINAL_PRIME</span>
      <span class="footer__copy">©{new Date().getFullYear()}_SYS_OP_v1.0.0</span>
    </div>

    <div class="footer__metrics">
      <div class="footer__metric">
        <span class="footer__metric-key">LOCAL_TIME</span>
        <span class="footer__metric-value" id="footer-clock">{systemTime}</span>
      </div>
      <div class="footer__metric">
        <span class="footer__metric-key">PROTOCOL</span>
        <span class="footer__metric-value">HTTPS/2</span>
      </div>
      <div class="footer__metric">
        <span class="footer__metric-key">RENDER</span>
        <span class="footer__metric-value">STATIC_SSG</span>
      </div>
      <div class="footer__metric footer__metric--status">
        <span class="footer__status-dot" aria-hidden="true"></span>
        <span class="footer__metric-value">ONLINE</span>
      </div>
    </div>
  </div>
</footer>

<script>
  function updateClock() {
    const el = document.getElementById('footer-clock');
    if (!el) return;
    const now = new Date();
    const hh = String(now.getUTCHours()).padStart(2, '0');
    const mm = String(now.getUTCMinutes()).padStart(2, '0');
    const ss = String(now.getUTCSeconds()).padStart(2, '0');
    el.textContent = `${hh}:${mm}:${ss}_GMT`;
  }

  document.addEventListener('astro:page-load', () => {
    updateClock();
    setInterval(updateClock, 1000);
  });
</script>

<style>
  .footer {
    border-top: var(--border-thin);
    padding-block: var(--space-6);
    margin-top: var(--space-24);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer__brand {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-on-bg);
    letter-spacing: var(--tracking-wide);
  }

  .footer__copy {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  .footer__metrics {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer__metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: flex-end;
  }

  .footer__metric--status {
    flex-direction: row;
    align-items: center;
    gap: var(--space-2);
  }

  .footer__metric-key {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-muted);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .footer__metric-value {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-on-bg);
    letter-spacing: var(--tracking-wide);
  }

  .footer__status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .footer__inner { flex-direction: column; align-items: flex-start; }
    .footer__metric { align-items: flex-start; }
    .footer__metrics { gap: var(--space-4); }
  }
</style>
