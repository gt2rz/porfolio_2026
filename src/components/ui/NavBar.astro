---
const navLinks = [
  { label: 'PROJECTS', href: '/#projects' },
  { label: 'STACK',    href: '/stack' },
  { label: 'MANIFESTO', href: '/manifesto' },
  { label: 'CONTACT',  href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="navbar" role="banner">
  <nav class="container navbar__inner" aria-label="Primary navigation">
    <a href="/" class="navbar__logo" aria-label="TERMINAL_PRIME — Home">
      <span class="navbar__logo-prefix" aria-hidden="true">~/</span>TERMINAL_PRIME
    </a>

    <ul class="navbar__links" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'navbar__link',
              { 'navbar__link--active': currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href.replace('/#projects', ''))) }
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button class="navbar__menu-btn" id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<!-- Mobile drawer -->
<div class="navbar__mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <ul role="list">
    {navLinks.map((link) => (
      <li>
        <a href={link.href} class="navbar__mobile-link">{link.label}</a>
      </li>
    ))}
  </ul>
</div>

<script>
  function initNav() {
    const btn = document.getElementById('menu-toggle');
    const drawer = document.getElementById('mobile-drawer');
    if (!btn || !drawer) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      drawer.setAttribute('aria-hidden', String(isOpen));
      drawer.classList.toggle('navbar__mobile-drawer--open', !isOpen);
      document.body.style.overflow = !isOpen ? 'hidden' : '';
    });

    // Close on link click
    drawer.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        btn.setAttribute('aria-expanded', 'false');
        drawer.setAttribute('aria-hidden', 'true');
        drawer.classList.remove('navbar__mobile-drawer--open');
        document.body.style.overflow = '';
      });
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: var(--border-thin);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .navbar__logo {
    font-family: var(--font-mono);
    font-size: var(--text-body-md);
    font-weight: 500;
    color: var(--color-on-bg);
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast);
  }

  .navbar__logo:hover {
    color: var(--color-primary);
  }

  .navbar__logo-prefix {
    color: var(--color-primary);
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
  }

  .navbar__link {
    font-family: var(--font-display);
    font-size: var(--text-label-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color var(--duration-fast);
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-primary);
    transition: width var(--duration-base) var(--ease-out-expo);
  }

  .navbar__link:hover,
  .navbar__link--active {
    color: var(--color-on-bg);
  }

  .navbar__link:hover::after,
  .navbar__link--active::after {
    width: 100%;
  }

  .navbar__link--active {
    color: var(--color-primary);
  }

  /* Mobile button */
  .navbar__menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  .navbar__menu-btn span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--color-on-bg);
    transition: all var(--duration-fast);
  }

  /* Mobile drawer */
  .navbar__mobile-drawer {
    display: none;
    position: fixed;
    top: 3.5rem;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-surface-low);
    z-index: calc(var(--z-nav) - 1);
    padding: var(--space-8) var(--container-px);
    transform: translateX(-100%);
    transition: transform var(--duration-base) var(--ease-out-expo);
  }

  .navbar__mobile-drawer ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .navbar__mobile-link {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-muted);
    transition: color var(--duration-fast);
  }

  .navbar__mobile-link:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .navbar__links { display: none; }
    .navbar__menu-btn { display: flex; }
    .navbar__mobile-drawer { display: block; }
    .navbar__mobile-drawer--open { transform: translateX(0); }
  }
</style>
