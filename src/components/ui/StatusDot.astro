---
import type { StatusColor } from '../../lib/types';

interface Props {
  status?: StatusColor;
  label?: string;
  pulse?: boolean;
}

const { status = 'online', label, pulse = false } = Astro.props;
---

<span class:list={['status-dot-wrap', label && 'status-dot-wrap--labeled']}>
  <span
    class:list={['status-dot', `status-dot--${status}`, pulse && 'status-dot--pulse']}
    aria-hidden="true"
  ></span>
  {label && (
    <span class="status-dot-label">{label}</span>
  )}
</span>

<style>
  .status-dot-wrap {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot--online  { background: var(--color-primary); }
  .status-dot--idle    { background: var(--color-secondary); }
  .status-dot--error   { background: var(--color-error); }

  .status-dot--pulse {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .status-dot-label {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-muted);
  }
</style>
