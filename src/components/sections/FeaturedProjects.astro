---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import Button from '../ui/Button.astro';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<section class="featured" id="projects" aria-labelledby="featured-title">
  <div class="container">
    <header class="featured__header gsap-reveal">
      <div class="featured__label">
        <span class="featured__label-text">SELECTED_REPOSITORIES</span>
        <span class="featured__count">PROJECT_COUNT:{String(allProjects.length).padStart(2, '0')}</span>
      </div>
      <h2 id="featured-title" class="featured__title">
        Featured<br />Work
      </h2>
    </header>

    <div class="featured__grid gsap-stagger">
      {featured.map((project, i) => (
        <ProjectCard
          slug={project.id}
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          role={project.data.role}
          status={project.data.status}
          index={i}
        />
      ))}
    </div>

    {allProjects.length > featured.length && (
      <div class="featured__more gsap-reveal">
        <Button href="/projects" variant="secondary">
          VIEW_ALL_PROJECTS ({String(allProjects.length).padStart(2, '0')})
        </Button>
      </div>
    )}
  </div>
</section>

<style>
  .featured {
    padding-block: var(--space-24);
  }

  .featured__header {
    margin-bottom: var(--space-12);
  }

  .featured__label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
    border-bottom: var(--border-thin);
    padding-bottom: var(--space-4);
  }

  .featured__label-text {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-primary);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .featured__count {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  .featured__title {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-bg);
    line-height: 1;
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1px;
    background: var(--color-outline-variant);
    border: 1px solid var(--color-outline-variant);
  }

  .featured__grid > * {
    background: var(--color-surface-low);
  }

  .featured__more {
    margin-top: var(--space-8);
    display: flex;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .featured__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
