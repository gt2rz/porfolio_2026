---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import CodeBlock from '../../components/sections/CodeBlock.astro';
import StatusDot from '../../components/ui/StatusDot.astro';
import ScrollAnimations from '../../components/islands/ScrollAnimations.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, tags, role, status, metrics, codeSnippet, codeLanguage, liveUrl, repoUrl } = project.data;

const statusColor: Record<string, 'online' | 'idle' | 'error'> = {
  LIVE_DEPLOYMENT: 'online',
  IN_DEVELOPMENT: 'idle',
  ARCHIVED: 'error',
};

// Get prev/next projects for navigation
const allProjects = await getCollection('projects');
const currentIdx = allProjects.findIndex((p: CollectionEntry<'projects'>) => p.id === project.id);
const prevProject = currentIdx > 0 ? allProjects[currentIdx - 1] : null;
const nextProject = currentIdx < allProjects.length - 1 ? allProjects[currentIdx + 1] : null;
---

<ProjectLayout
  title={`${title} — GT2RZ.DEV`}
  description={description}
>
  <article class="project-detail container section--lg">

    <!-- Hero -->
    <header class="project-detail__hero gsap-reveal">
      <div class="project-detail__status-bar">
        <StatusDot status={statusColor[status]} label={status} pulse />
        <span class="project-detail__role">{role}</span>
      </div>

      <h1
        class="project-detail__title"
        transition:name={`project-title-${project.id}`}
      >
        {title}
      </h1>

      <p class="project-detail__description">{description}</p>

      <div class="project-detail__meta">
        <div class="project-detail__tags">
          {tags.map(tag => (
            <Badge variant="tech">[{tag}]</Badge>
          ))}
        </div>
        <div class="project-detail__links">
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="project-detail__link">
              LIVE_DEMO →
            </a>
          )}
          {repoUrl && (
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="project-detail__link">
              SOURCE_CODE →
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- Metrics panel -->
    {metrics && Object.keys(metrics).length > 0 && (
      <div class="project-detail__metrics gsap-stagger">
        {Object.entries(metrics).map(([key, value]) => (
          <div class="project-detail__metric">
            <span class="project-detail__metric-value">{value}</span>
            <span class="project-detail__metric-key">{key.toUpperCase()}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Code snippet -->
    {codeSnippet && (
      <div class="project-detail__code gsap-reveal">
        <CodeBlock
          code={codeSnippet}
          language={codeLanguage ?? 'typescript'}
          title={`${title.toLowerCase().replace(/\s/g, '_')}.snippet`}
        />
      </div>
    )}

    <!-- MDX content -->
    <div class="project-detail__content gsap-reveal prose">
      <Content />
    </div>

    <!-- Specs table -->
    {metrics && (
      <div class="project-detail__specs gsap-reveal">
        <h2 class="project-detail__specs-title">SPECIFICATIONS</h2>
        <div class="project-detail__specs-table">
          {Object.entries(metrics).map(([key, value]) => (
            <div class="project-detail__spec-row">
              <span class="project-detail__spec-key">{key.toUpperCase()}</span>
              <span class="project-detail__spec-value">{value}</span>
            </div>
          ))}
          <div class="project-detail__spec-row">
            <span class="project-detail__spec-key">ROLE</span>
            <span class="project-detail__spec-value">{role}</span>
          </div>
          <div class="project-detail__spec-row">
            <span class="project-detail__spec-key">STATUS</span>
            <span class="project-detail__spec-value" style="color: var(--color-primary)">{status}</span>
          </div>
        </div>
      </div>
    )}
  </article>

  <!-- Prev / Next navigation -->
  <nav class="project-nav container" aria-label="Project navigation">
    <div class="project-nav__inner">
      {prevProject ? (
        <a href={`/projects/${prevProject.slug}`} class="project-nav__link project-nav__link--prev">
          <span class="project-nav__dir">← PREV_PROJECT</span>
          <span class="project-nav__title">{prevProject.data.title}</span>
        </a>
      ) : <div />}
      {nextProject ? (
        <a href={`/projects/${nextProject.slug}`} class="project-nav__link project-nav__link--next">
          <span class="project-nav__dir">NEXT_PROJECT →</span>
          <span class="project-nav__title">{nextProject.data.title}</span>
        </a>
      ) : <div />}
    </div>
  </nav>

  <ScrollAnimations />
</ProjectLayout>

<style>
  .project-detail {
    padding-top: calc(3.5rem + var(--space-16));
  }

  .project-detail__hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 800px;
    margin-bottom: var(--space-12);
  }

  .project-detail__status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .project-detail__role {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
    border: 1px solid var(--color-outline-variant);
    padding: 2px var(--space-3);
  }

  .project-detail__title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-bg);
    line-height: 1;
  }

  .project-detail__description {
    font-family: var(--font-mono);
    font-size: var(--text-body-md);
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 60ch;
  }

  .project-detail__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    justify-content: space-between;
  }

  .project-detail__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .project-detail__links {
    display: flex;
    gap: var(--space-6);
  }

  .project-detail__link {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-primary);
    letter-spacing: var(--tracking-wide);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .project-detail__link:hover {
    color: var(--color-primary-dim);
  }

  /* Metrics row */
  .project-detail__metrics {
    display: flex;
    gap: 1px;
    background: var(--color-outline-variant);
    border: 1px solid var(--color-outline-variant);
    margin-bottom: var(--space-12);
  }

  .project-detail__metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-6);
    background: var(--color-surface-low);
    flex: 1;
    transition: background var(--duration-fast);
  }

  .project-detail__metric:hover {
    background: var(--color-surface-hi);
  }

  .project-detail__metric-value {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-primary);
  }

  .project-detail__metric-key {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wider);
  }

  .project-detail__code {
    margin-bottom: var(--space-12);
  }

  /* MDX prose styles */
  .prose {
    max-width: 72ch;
    margin-bottom: var(--space-16);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-bg);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .prose :global(p) {
    font-family: var(--font-mono);
    font-size: var(--text-body-md);
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .prose :global(li) {
    font-family: var(--font-mono);
    font-size: var(--text-body-md);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .prose :global(strong) {
    color: var(--color-on-bg);
    font-weight: 600;
  }

  /* Specs table */
  .project-detail__specs {
    margin-bottom: var(--space-16);
  }

  .project-detail__specs-title {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-4);
  }

  .project-detail__specs-table {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-outline-variant);
    border: 1px solid var(--color-outline-variant);
    max-width: 500px;
  }

  .project-detail__spec-row {
    display: flex;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-low);
    gap: var(--space-8);
  }

  .project-detail__spec-key {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  .project-detail__spec-value {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-on-bg);
    text-align: right;
  }

  /* Navigation */
  .project-nav {
    padding-block: var(--space-12);
    border-top: var(--border-thin);
    margin-top: 0;
  }

  .project-nav__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .project-nav__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-6);
    background: var(--color-surface-low);
    border: var(--border-thin);
    text-decoration: none;
    transition: background var(--duration-fast), border-color var(--duration-fast);
  }

  .project-nav__link:hover {
    background: var(--color-surface-hi);
    border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
  }

  .project-nav__link--next {
    text-align: right;
  }

  .project-nav__dir {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    color: var(--color-primary);
    letter-spacing: var(--tracking-wide);
  }

  .project-nav__title {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 600;
    color: var(--color-on-bg);
    letter-spacing: var(--tracking-tight);
  }

  @media (max-width: 768px) {
    .project-detail__metrics { flex-direction: column; }
    .project-nav__inner { grid-template-columns: 1fr; }
  }
</style>
