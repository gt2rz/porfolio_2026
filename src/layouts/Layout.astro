---
import { ClientRouter } from 'astro:transitions';
import NavBar from '../components/ui/NavBar.astro';
import Footer from '../components/ui/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'TERMINAL_PRIME — Senior Frontend Architect',
  description = 'Portfolio of a senior frontend architect specializing in distributed systems, performance engineering, and developer experience.',
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://localhost:4321');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- View Transitions (Astro 6) -->
    <ClientRouter />

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Atmospheric grain overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <NavBar />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Lenis smooth scroll + GSAP ScrollTrigger init -->
    <script>
      import { initLenis } from '../lib/lenis';

      function init() {
        initLenis();
      }

      // Init on first load and after every View Transition navigation
      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
